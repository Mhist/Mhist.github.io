cmd控制台反馈如下：&lt;pre&gt;
C:\Users\18827\AppData\Roaming\npm\create-react-app -&gt; C:\Users\18827\AppData\Roaming\npm\node_modules\create-react-app\index.js&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;a href=&quot;mailto:&amp;#x2b;&amp;#99;&amp;#x72;&amp;#x65;&amp;#x61;&amp;#116;&amp;#101;&amp;#45;&amp;#x72;&amp;#x65;&amp;#97;&amp;#99;&amp;#116;&amp;#45;&amp;#x61;&amp;#112;&amp;#112;&amp;#x40;&amp;#52;&amp;#x2e;&amp;#x30;&amp;#x2e;&amp;#x33;&quot;&gt;&amp;#x2b;&amp;#99;&amp;#x72;&amp;#x65;&amp;#x61;&amp;#116;&amp;#101;&amp;#45;&amp;#x72;&amp;#x65;&amp;#97;&amp;#99;&amp;#116;&amp;#45;&amp;#x61;&amp;#112;&amp;#112;&amp;#x40;&amp;#52;&amp;#x2e;&amp;#x30;&amp;#x2e;&amp;#x33;&lt;/a&gt;&lt;br&gt;added 67 packages from 25 contributors in 22.805s&lt;br&gt; &lt;/pre&gt;&lt;/p&gt;
