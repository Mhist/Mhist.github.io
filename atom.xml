    <summary type="html">&lt;h1 id=&quot;react-入门&quot;&gt;&lt;a href=&quot;#react-入门&quot; class=&quot;headerlink&quot; title=&quot;react 入门&quot;&gt;&lt;/a&gt;react 入门&lt;/h1&gt;&lt;h2 id=&quot;react框架基本介绍&quot;&gt;&lt;a href=&quot;#react框架基本介绍&quot; class=&quot;headerlink&quot; title=&quot;react框架基本介绍&quot;&gt;&lt;/a&gt;react框架基本介绍&lt;/h2&gt;&lt;p&gt;   &lt;a href=&quot;https://reactjs.org/&quot;&gt;react官方&lt;/a&gt;&lt;/p&gt;
&lt;h2 id=&quot;开发环境及脚手架安装&quot;&gt;&lt;a href=&quot;#开发环境及脚手架安装&quot; class=&quot;headerlink&quot; title=&quot;开发环境及脚手架安装&quot;&gt;&lt;/a&gt;开发环境及脚手架安装&lt;/h2&gt;&lt;ul&gt;
